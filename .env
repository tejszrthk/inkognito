# ──────────────────────────────────────────────────────────────
# Inkognito — Environment Configuration
# Copy this file to .env and fill in your keys.
# Lines starting with # are comments and are ignored.
# ──────────────────────────────────────────────────────────────


# ── REQUIRED KEYS ─────────────────────────────────────────────
# Pipeline will not run usefully without these three.

# LegalKart API — eCourts + NCLT case search
# Get from: legalkart.com/api-partner
LEGALKART_API_KEY=lk_sbx_secret_9a865d7cca828e30d65fa2b6696491822b622b4c43b1d22ae25d9cdb22e3d697e9c7

# SerpAPI — Google search + social media discovery + reverse image
# Get from: serpapi.com (free trial: 100 searches/day)
SERP_API_KEY=82fe6b169ddb7b15ccb45eb3b9f0d9a0df8c7d21620b0698c1cee3fa2fdf476e

# MCA21 provider — choose one: surepass | sandbox | compdata
MCA_API_PROVIDER=sandbox

# MCA21 API key — from whichever provider above
# Surepass: surepass.io | Sandbox: sandbox.co.in | Compdata: compdata.in
MCA_API_KEY=key_live_fe211d92be59472e9dc191187d2bba07
MCA_API_SECRET=secret_live_aef8e5c9b9364ed597bd4f1dc2b91aa6


# ── OPTIONAL KEYS — module degrades gracefully if not set ─────

# 2captcha — needed for IGRS UP property search (has CAPTCHA)
# Get from: 2captcha.com | ~$1 per 1000 solves
CAPTCHA_API_KEY=

# Scrapin.io — LinkedIn full work history (without this, only name/headline)
# Get from: scrapin.io | ~$0.01/profile
SCRAPIN_API_KEY=

# TinEye — exact image copy detection
# Get from: tineye.com/api | Paid
TINEYE_API_KEY=

# imgbb.com — needed to host photos for reverse image search
# Get from: imgbb.com (free account, free API key)
IMGBB_API_KEY=4b97c8d80888bfd8124efd4fe9c7bc9b

# Truecaller — name + spam score lookup by phone number
# Setup: pip install truecallerpy → truecallerpy login +91XXXXXXXXXX
# Copy the installationId printed after OTP verification
TRUECALLER_INSTALL_ID=


# ── DEBUG ──────────────────────────────────────────────────────
# Set to DEBUG to see full request/response logs
# Set to INFO (default) for clean output
LOG_LEVEL=INFO
